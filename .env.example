# Copy to .env and fill in.  Never commit .env.
#
# Required: absolute path to the Bun-fork Zig binary.
# See docs/bun-zig-toolchain.md.
ZIGIX_BUN_ZIG=/absolute/path/to/bun-zig

# Optional: substring that must appear in `zig version` output. Used as a
# best-effort pin (the wrapper cannot prove fork identity by itself).
# ZIGIX_BUN_ZIG_PINNED_VERSION=

# Optional: set to 1 if you intentionally installed the Bun-fork binary at a
# system-looking path such as /usr/local/bin/zig.
# ZIGIX_ALLOW_SYSTEM_ZIG=0

# Optional: set to 0 to silence the per-invocation toolchain identity log line.
# ZIGIX_LOG_TOOLCHAIN=1

# Optional: where the QEMU smoke harness writes the captured serial log.
# ZIGIX_SERIAL_LOG=zig-out/serial.log

# Optional: how long the QEMU smoke harness allows the kernel to run.
# ZIGIX_QEMU_TIMEOUT=30
